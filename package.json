{
  "name": "vrchat-fish-guide",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial community guide and probability calculator for the VRChat world Fish!",
  "homepage": "https://metyatech.github.io/vrchat-fish-guide/",
  "repository": {
    "type": "git",
    "url": "https://github.com/metyatech/vrchat-fish-guide.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/vrchat-fish-guide/issues"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern .next --ignore-pattern out --ignore-pattern coverage --ignore-pattern playwright-report --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern .next --ignore-pattern out --ignore-pattern coverage --ignore-pattern playwright-report --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:a11y",
    "test:unit": "vitest run src/test/calculator.test.ts src/test/distributions.test.ts",
    "test:a11y": "vitest run src/test/accessibility.test.tsx",
    "test:e2e": "playwright install chromium && playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.4.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
