{
  "name": "vrchat-fish-guide",
  "version": "0.12.42",
  "private": true,
  "description": "Unofficial community guide and probability calculator for the VRChat world Fish!",
  "homepage": "https://metyatech.github.io/vrchat-fish-guide/",
  "repository": {
    "type": "git",
    "url": "https://github.com/metyatech/vrchat-fish-guide.git"
  },
  "bugs": {
    "url": "https://github.com/metyatech/vrchat-fish-guide/issues"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/serve-static.mjs out",
    "serve:e2e": "node scripts/serve-static.mjs out 3001",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:a11y",
    "test:unit": "vitest run src/test/calculator.test.ts src/test/distributions.test.ts src/test/next-config.test.ts src/test/metadata-routes.test.ts src/test/url-state.test.ts src/test/ranking.test.ts src/test/parameter-form.test.tsx src/test/ui-quality.test.tsx src/test/site-version.test.tsx",
    "test:a11y": "vitest run src/test/accessibility.test.tsx",
    "test:e2e": "playwright install chromium && npm run build && node scripts/run-e2e.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
